{
  "sourcePolicy": {
    "enabled": true,
    "preset": "strict-app",
    "enforcement": "error",
    "failOnViolation": true,
    "maxFrontierComponentsPerFile": 1,
    "maxLinesPerFile": 320,
    "maxCharsPerFile": 24000,
    "localImportExtensions": "source",
    "allowedLocalImportExtensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".json",
      ".node",
      ".ts",
      ".tsx",
      ".jsx"
    ],
    "sourceExtensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx"
    ],
    "excludedSegments": [
      "node_modules",
      "dist",
      "build",
      "coverage",
      "results",
      "reports",
      "agent-runs",
      "agent-worktrees",
      ".cache",
      ".next",
      ".turbo",
      "out"
    ],
    "allowedOversizedFiles": {}
  }
}
